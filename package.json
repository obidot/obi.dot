{
  "name": "obidot",
  "version": "0.0.0",
  "private": true,
  "description": "Obidot — Autonomous Cross-Chain Finance Layer for Polkadot",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:forge": "pnpm --filter pvm-core run test:forge",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "clean": "turbo run clean",

    "agent:dev": "pnpm --filter @obidot/agent run dev",
    "agent:build": "pnpm --filter @obidot/agent run build",
    "agent:start": "pnpm --filter @obidot/agent run start",
    "agent:typecheck": "pnpm --filter @obidot/agent run typecheck",
    "agent:lint": "pnpm --filter @obidot/agent run lint",
    "agent:format": "pnpm --filter @obidot/agent run format",

    "app:dev": "pnpm --filter @obidot/app run dev",
    "app:build": "pnpm --filter @obidot/app run build",
    "app:start": "pnpm --filter @obidot/app run start",
    "app:typecheck": "pnpm --filter @obidot/app run typecheck",
    "app:lint": "pnpm --filter @obidot/app run lint",
    "app:format": "pnpm --filter @obidot/app run format"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
