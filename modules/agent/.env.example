# ── Chain ─────────────────────────────────────────────────
# Polkadot Hub TestNet (chain 420420417) — production uses mainnet (420420419)
RPC_URL="https://eth-rpc-testnet.polkadot.io/"

# Deployed ObidotVault address (Polkadot Hub TestNet, Phase 8)
VAULT_ADDRESS="0x03473a95971Ba0496786a615e21b1e87bDFf0025"

# Vault underlying ERC-20 asset (NativeAssetDOT on TestNet)
ASSET_ADDRESS="0xE72453bD8d5ECF56ccdDeF949C8AE0Cea5A41E7d"

# ── LLM Provider ──────────────────────────────────────────
# Provider: "openai" (default) | "anthropic" | "openrouter"
LLM_PROVIDER="openai"

# Model name (overrides provider default)
# openai:     gpt-4o (default)
# anthropic:  claude-sonnet-4-5 (default)
# openrouter: anthropic/claude-sonnet-4 (default)
LLM_MODEL="gpt-4o"

# OpenAI API key (required for openai/openrouter providers)
OPENAI_API_KEY=""

# Anthropic API key (required for anthropic provider)
ANTHROPIC_API_KEY=""

# ── Agent ─────────────────────────────────────────────────
# Hex-encoded private key of the strategist agent wallet (0x-prefixed)
# Must hold STRATEGIST_ROLE on ObidotVault.
AGENT_PRIVATE_KEY=""

# Autonomous loop interval in minutes
LOOP_INTERVAL_MINUTES=5

# Maximum single strategy amount (18-decimal string, default 100k)
MAX_STRATEGY_AMOUNT="100000000000000000000000"

# Maximum slippage in basis points (1-500, default 100 = 1%)
DEFAULT_MAX_SLIPPAGE_BPS=100

# Intent deadline offset in seconds (default 600 = 10 minutes)
INTENT_DEADLINE_SECONDS=600

# ── Oracle ────────────────────────────────────────────────
KEEPER_ORACLE_ADDRESS="0xf64d93DC125AC1B366532BBbA165615f6D566C7F"
ORACLE_REGISTRY_ADDRESS="0x8b7C7345d6cF9de45f4aacC61F56F0241d47e88B"

# ── DEX Aggregator ────────────────────────────────────────
SWAP_ROUTER_ADDRESS="0xfbc3fEB4DA6f00049af278eC3ecaCAFF7f08DDbB"
SWAP_QUOTER_ADDRESS="0x81d7aCFEF474DA6c76eC1b5A05a137cB9f3A5Db1"

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL="info"
