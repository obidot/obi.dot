# ─────────────────────────────────────────────────────────────────────────────
#  Obidot Autonomous CFO — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key for GPT-4o reasoning
OPENAI_API_KEY=sk-...

# Agent's secp256k1 private key (0x-prefixed, 64 hex chars)
# This key must hold the STRATEGIST_ROLE on the ObidotVault contract.
AGENT_PRIVATE_KEY=0x...

# Deployed ObidotVault contract address
VAULT_ADDRESS=0x...

# Underlying ERC-20 asset address (the vault's base token)
ASSET_ADDRESS=0x...

# ── Optional (defaults shown) ────────────────────────────────────────────────

# Polkadot Hub EVM RPC endpoint
# RPC_URL=https://services.polkadothub-rpc.com/testnet

# Autonomous loop interval (minutes between cycles)
# LOOP_INTERVAL_MINUTES=5

# Log level: fatal | error | warn | info | debug | trace
# LOG_LEVEL=info

# Maximum single strategy deployment (wei)
# MAX_STRATEGY_AMOUNT=100000000000000000000000

# Default max slippage (basis points, 100 = 1%)
# DEFAULT_MAX_SLIPPAGE_BPS=100

# EIP-712 intent deadline offset (seconds from now)
# INTENT_DEADLINE_SECONDS=600

# ── Telegram Bot (optional) ──────────────────────────────────────────────────

# Telegram bot token from @BotFather. When set, enables the Telegram bot
# alongside the autonomous agent loop.
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmnOPQrSTUvwxYZ
