# ── Chain ─────────────────────────────────────────────────
# Polkadot Hub TestNet (chain 420420417) — production uses mainnet (420420419)
RPC_URL="https://eth-rpc-testnet.polkadot.io/"

# Deployed ObidotVault address (Polkadot Hub TestNet, Phase 8)
VAULT_ADDRESS="0x03473a95971Ba0496786a615e21b1e87bDFf0025"

# Vault underlying ERC-20 asset (TestDOT on TestNet)
ASSET_ADDRESS="0x2402C804aD8a6217BF73D8483dA7564065c56083"

# ── LLM Provider ──────────────────────────────────────────
# Provider: "openai" (default) | "anthropic" | "openrouter"
LLM_PROVIDER="openai"

# Model name (overrides provider default)
# openai:     gpt-4o (default)
# anthropic:  claude-sonnet-4-5 (default)
# openrouter: anthropic/claude-sonnet-4 (default)
LLM_MODEL="gpt-4o"

# OpenAI API key (required for openai/openrouter providers)
OPENAI_API_KEY=""

# Anthropic API key (required for anthropic provider)
ANTHROPIC_API_KEY=""

# ── Agent ─────────────────────────────────────────────────
# Hex-encoded private key of the strategist agent wallet (0x-prefixed)
# Must hold STRATEGIST_ROLE on ObidotVault.
AGENT_PRIVATE_KEY=""

# Autonomous loop interval in minutes
LOOP_INTERVAL_MINUTES=5

# Maximum single strategy amount (18-decimal string, default 100k)
MAX_STRATEGY_AMOUNT="100000000000000000000000"

# Maximum slippage in basis points (1-500, default 100 = 1%)
DEFAULT_MAX_SLIPPAGE_BPS=100

# Intent deadline offset in seconds (default 600 = 10 minutes)
INTENT_DEADLINE_SECONDS=600

# ── Oracle ────────────────────────────────────────────────
KEEPER_ORACLE_ADDRESS="0xf64d93DC125AC1B366532BBbA165615f6D566C7F"
ORACLE_REGISTRY_ADDRESS="0x8b7C7345d6cF9de45f4aacC61F56F0241d47e88B"

# ── DEX Aggregator ────────────────────────────────────────
# SwapRouter v3
SWAP_ROUTER_ADDRESS="0x0A85A1B0bb893cab3b5fad7312ac241e92C8Badf"
# SwapQuoter
SWAP_QUOTER_ADDRESS="0x81d7aCFEF474DA6c76eC1b5A05a137cB9f3A5Db1"
# HydrationOmnipoolAdapter (Phase 15, PALLET_OMNIPOOL=59)
HYDRATION_ADAPTER_ADDRESS="0xF0E1c10f97446C032A86C9643258Bb26d6129933"
# AssetHubPairAdapter
ASSET_HUB_ADAPTER_ADDRESS="0x67E0B572A7761C13D7C9A3f737C825A506a85CF4"
# BifrostDEXAdapter
BIFROST_DEX_ADAPTER_ADDRESS="0x386FC9514594c589ad7481AFC3eC36216DE91dC0"

# ── Cross-Chain ────────────────────────────────────────────
# CrossChainRouter on Polkadot Hub
CROSS_CHAIN_ROUTER_ADDRESS="0xE2fFfb3B5C72f99811bC20D857035611bFCe5b5d"
# BifrostAdapter on Polkadot Hub
BIFROST_ADAPTER_ADDRESS="0x265Cb785De0fF2e5BcebDEb53095aDCAE9175527"

# ── Satellite EVM Chains (optional) ───────────────────────
# Ethereum Sepolia (testnet)
# ETH_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
# ETH_SATELLITE_VAULT=""

# Arbitrum Sepolia (testnet)
# ARB_RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"
# ARB_SATELLITE_VAULT=""

# Base Sepolia (testnet)
# BASE_RPC_URL="https://sepolia.base.org"
# BASE_SATELLITE_VAULT=""

# Optimism Sepolia (testnet)
# OP_RPC_URL="https://sepolia.optimism.io"
# OP_SATELLITE_VAULT=""

# ── Telegram Bot (optional) ───────────────────────────────
# TELEGRAM_BOT_TOKEN=""

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL="info"

# API server port
API_PORT=3011
